{
  "name": "telegram-ai-relay-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram bot that relays messages to OpenAI / Anthropic / Gemini, hosted on AWS Lambda.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx scripts/local-dev.ts",
    "set-webhook": "tsx scripts/set-webhook.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-lambda": "^3.1037.0",
    "@aws-sdk/client-ssm": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@google/genai": "^1.0.0",
    "@grammyjs/auto-retry": "^2.0.2",
    "@grammyjs/stream": "^1.0.1",
    "grammy": "^1.42.0",
    "openai": "^4.80.0",
    "telegramify-markdown": "^1.3.3"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.146",
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
