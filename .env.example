# ─── Local dev (.env.local) ────────────────────────────────────────────────
# Copy this file to .env.local and fill in. Used by scripts/local-dev.ts.
# In production the same values are read from AWS SSM Parameter Store, not env.

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=local-dev-not-used

# AI providers (only the ones you intend to test locally)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Auth + budget
# Comma-separated Telegram numeric user IDs allowed to use the bot.
ALLOWED_USER_IDS=
# Daily USD cap per user (token-based estimate, not exact billing).
DAILY_USD_CAP_PER_USER=2.00

# Storage backend selector for local dev: "memory" or "dynamodb"
STORAGE_BACKEND=memory
# Only used when STORAGE_BACKEND=dynamodb
TABLE_NAME=tg-ai-relay-bot
AWS_REGION=eu-west-1
